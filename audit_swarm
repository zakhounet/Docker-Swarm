services:
  traefik:
    image: traefik:v3.6.5
    command:
      - "--log.level=DEBUG"
      - "--global.checknewversion=false"
      - "--global.sendanonymoususage=false"
      - "--api.dashboard=true"
      # --- Provider Swarm ---
      - "--providers.swarm=true"
      - "--providers.swarm.network=proxy"
      - "--providers.swarm.exposedByDefault=false"
      # --- Provider File (Approche Lempa) ---
      - "--providers.file.directory=/etc/traefik/rules"
      - "--providers.file.watch=true"
      # --- Entrypoints ---
      - "--entrypoints.web.address=:80"
      - "--entrypoints.websecure.address=:443"
      # --- Certificats Cloudflare (DNS Challenge) ---
      #- "--certificatesresolvers.cloudflare.acme.caserver=https://acme-staging-v02.api.letsencrypt.org/directory"
      - "--certificatesresolvers.cloudflare.acme.dnschallenge=true"
      - "--certificatesresolvers.cloudflare.acme.dnschallenge.provider=cloudflare"
      - "--certificatesresolvers.cloudflare.acme.email=fnb2@orange.fr"
      - "--certificatesresolvers.cloudflare.acme.storage=/etc/traefik/acme.json"
      - "--certificatesresolvers.cloudflare.acme.preferredchain=ISRG Root X1" #pour Portainer secure
      # --- SOLUTIONS SOURCE POUR MODE GLOBAL (Stabilisation) ---
      - "--certificatesresolvers.cloudflare.acme.dnschallenge.resolvers=1.1.1.1:53,1.0.0.1:53"
      - "--certificatesresolvers.cloudflare.acme.dnschallenge.propagation.delaybeforechecks=60"
      - "--certificatesresolvers.cloudflare.acme.dnschallenge.disablepropagationcheck=true"

      - "--providers.swarm.endpoint=unix:///var/run/docker.sock"
    networks:
      - proxy
    ports:
      - target: 80
        published: 80
        protocol: tcp
        mode: host
      - target: 443
        published: 443
        protocol: tcp
        mode: host
    volumes:
      - "/mnt/cephfs/docker-cluster/Docker-Swarm/traefik/data/acme.json:/etc/traefik/acme.json"
      - "/mnt/cephfs/docker-cluster/Docker-Swarm/traefik/rules:/etc/traefik/rules:ro"
      - "/var/run/docker.sock:/var/run/docker.sock:ro"
    environment:
      - CF_API_EMAIL=fnb2@orange.fr
      - CF_API_KEY=59caaee466390f1db7c67c90db68d14fc515f
      - TZ=Europe/Paris
    deploy:
      mode: global
      #replicas: 1  # Remplacez temporairement "mode: global" par ceci pour le débogage
      placement:
        constraints:
          - node.role == manager
      update_config:
        parallelism: 1
        delay: 10s
      restart_policy:
        condition: on-failure
      labels:
        - "traefik.enable=true"
        - "traefik.swarm.network=proxy"
        # --- Configuration du Certificat Wildcard (Approche Lempa) ---
        - "traefik.http.routers.wildcard-certs.tls.certresolver=cloudflare"
        - "traefik.http.routers.wildcard-certs.tls.domains[0].main=test.teamfnb.com"
        - "traefik.http.routers.wildcard-certs.tls.domains[0].sans=*.test.teamfnb.com, fix.lefix.test.teamfnb.com"
        
        # --- Dashboard Traefik ---
        - "traefik.http.routers.traefik-dash.rule=Host(`traefik-dashboard1.test.teamfnb.com`)"
        - "traefik.http.routers.traefik-dash.service=api@internal"
        - "traefik.http.routers.traefik-dash.entrypoints=websecure"
        - "traefik.http.routers.traefik-dash.tls=true"
        - "traefik.http.services.traefik-dash.loadbalancer.server.port=8080"
    logging:
        driver: "json-file"
        options:
          max-size: "10m"
          max-file: "3"

networks:
  proxy:
    external: true
